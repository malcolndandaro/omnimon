# ─────────────────────────────────────────────────────────────────────
# Omnimon configuration — copy to .env and fill in.
# `setup.sh` will copy this file and mint the secret values for you.
# ─────────────────────────────────────────────────────────────────────

# The ONE variable that drives the whole deployment. It sets Caddy's
# site address, the Omnigent public base URL, and (from slice 02) the
# Google OAuth callback URL.
#   • Local run:  OMNIMON_DOMAIN=localhost   (Caddy serves a trusted local cert)
#   • Server run: OMNIMON_DOMAIN=agents.example.com
#                 (point a DNS A record at the box first; Caddy then
#                  fetches a real Let's Encrypt certificate automatically)
OMNIMON_DOMAIN=localhost

# ── Upstream Omnigent image (ADR-0001: pinned, never "latest") ────────
OMNIGENT_IMAGE=ghcr.io/omnigent-ai/omnigent-server
OMNIGENT_IMAGE_TAG=v0.1.0

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=omnigent
POSTGRES_DB=omnigent
# Minted by setup.sh. Never commit a real value.
POSTGRES_PASSWORD=

# ── Authentication: Google sign-in (OIDC) ────────────────────────────
# On in every environment (localhost mirrors prod).
OMNIGENT_AUTH_ENABLED=1

# Create an OAuth 2.0 *Web application* client in Google Cloud Console and
# paste its credentials here. Authorized redirect URI must be exactly:
#   https://<OMNIMON_DOMAIN>/auth/callback
# (for local dev: https://localhost/auth/callback)
OMNIGENT_OIDC_CLIENT_ID=
OMNIGENT_OIDC_CLIENT_SECRET=

# Minted by setup.sh — signs the OIDC session cookie (hex, >=32 bytes).
# Never commit a real value.
OMNIGENT_OIDC_COOKIE_SECRET=

# ── Authorization: who may sign in ────────────────────────────────────
# Comma-separated email allowlist. These accounts are made Omnigent admins
# AND must be the *exact* Google OAuth "test users" on your OAuth consent
# screen (keep the app in "Testing" status). Google then refuses to issue a
# token to anyone else, which is what actually enforces single-user access.
OMNIMON_ALLOWED_EMAILS=you@example.com

# Leave 0 to forbid open signup. Set 1 only if you intend to hand out
# one-time invite links to users outside the allowlist.
OMNIGENT_OIDC_ALLOW_INVITES=0

# ── Runner: Claude Code subscription auth (headless) ──────────────────
# The runner executes agent sessions with Claude Code. Authenticate once
# with your Claude subscription to get a long-lived token:
#   docker compose exec omnigent-runner claude setup-token
# (open the printed URL, approve, paste the code back), then paste the
# resulting token here. Never commit a real value.
CLAUDE_CODE_OAUTH_TOKEN=
